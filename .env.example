# AI Provider Configuration
# Works with Anthropic Claude, GitHub Models, or Microsoft Foundry.

# =============================================================================
# OPTION 1: Anthropic Claude (chat) + GitHub Models (embeddings) — Recommended
# =============================================================================
# Chat uses Claude; embeddings use GitHub Models (free, no extra cost).
# Get your Anthropic API key at: https://console.anthropic.com/settings/keys
# Get your GitHub fine-grained PAT at: https://github.com/settings/personal-access-tokens/new
#   Permission: Account permissions → Models → Read (models:read)

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=claude-sonnet-4-5
GITHUB_MODELS_KEY=your_github_fine_grained_pat_here
AI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# OPTION 2: GitHub Models (Free - Good for Learning)
# =============================================================================
# Uncomment these lines and remove/comment the OPTION 1 block above.
# Get your GitHub Personal Access Token at: https://github.com/settings/tokens

# AI_API_KEY=your_github_personal_access_token
# AI_ENDPOINT=https://models.inference.ai.azure.com
# AI_MODEL=gpt-5-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# OPTION 3: Microsoft Foundry (Paid - For Production)
# =============================================================================
# AI_API_KEY=your_azure_openai_api_key
# AI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
# AI_MODEL=gpt-5-mini
# AI_EMBEDDING_MODEL=text-embedding-3-small
